@model List<QuanLyDiemSinhVien.Models.AttendanceModel>
@{
    var session = ViewBag.Session as QuanLyDiemSinhVien.Models.AttendanceSessionModel;
    var studentCount = Model.Count;
}

<div style="padding-top:20px;margin-left:20px">
    <h3>Điểm danh - @session?.CourseSection.SectionCode - @session?.CourseSection.Course.CourseName</h3>
    <p>Số sinh viên: <strong>@studentCount</strong></p>

    <form asp-action="Mark" method="post">
        <table class="table table-bordered">
            <thead>
                <tr>
                    <th>STT</th>
                    <th>Ma sinh viên</th>
                    <th>Họ tên</th>
                    <th>Có mặt</th>
                    <th>Vắng phép</th>
                    <th>Vắng không phép</th>
                    <th>Muộn</th>
                    <th>Ghi chú</th>
                </tr>
            </thead>
            <tbody>
                @for (int i = 0; i < studentCount; i++)
                {
                    var attendance = Model[i];
                    <tr>
                        <td>@(i + 1)</td>
                        <td>@attendance.Student.StudentCode</td>
                        <td>@attendance.Student.FullName</td>
                        
                        <td>
                            <input type="radio" name="[@i].AttendanceStatus" value="1" @(attendance.AttendanceStatus == 1 ? "checked" : "") />
                        </td>
                        <td>
                            <input type="radio" name="[@i].AttendanceStatus" value="2" @(attendance.AttendanceStatus == 2 ? "checked" : "") />
                        </td>
                        <td>
                            <input type="radio" name="[@i].AttendanceStatus" value="3" @(attendance.AttendanceStatus == 3 ? "checked" : "") />
                        </td>
                        <td>
                            <input type="radio" name="[@i].AttendanceStatus" value="4" @(attendance.AttendanceStatus == 4 ? "checked" : "") />
                        </td>
                        <td>
                            <input type="text" name="[@i].Note" value="@attendance.Note" class="form-control" />
                        </td>

                        <!-- Hidden fields -->
                        <input type="hidden" name="[@i].AttendanceId" value="@attendance.AttendanceId" />
                        <input type="hidden" name="[@i].AttendanceSessionId" value="@attendance.AttendanceSessionId" />
                    </tr>
                }
            </tbody>
        </table>

        <button type="submit" class="btn btn-primary">Lưu điểm danh</button>
    </form>

</div>