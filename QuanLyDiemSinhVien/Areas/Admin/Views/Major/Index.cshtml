@model IEnumerable<MajorModel>

@{
    ViewData["Title"] = "Danh Sách Ngành Học";
}

<div>
    <div class="d-flex align-items-center justify-content-between" style="margin:0px 70px 15px 30px; padding-top:20px;">
        <h3 class="mb-0">Quản lý ngành học</h3>

        <form asp-action="Search" method="get" class="d-flex" style="max-width:400px;">
            <input type="text" name="searchString" class="form-control me-2" placeholder="Tìm kiếm theo mã hoặc tên" value="@ViewBag.SearchString" />
            <button type="submit" class="btn btn-primary">Tìm</button>
        </form>
    </div>
    <div style="margin-left:30px;padding-top:20px">
        <a class="btn btn-primary mb-3" asp-action="Create" asp-controller="Major">Thêm Ngành Học</a>
    </div>
    <div class="col-sm-12" style="margin-left:5px">
        <table class="table table-bordered table-hover" id="myTable">
            <thead>
                <tr>
                    <th>STT</th>
                    <th>Mã Ngành Học</th>
                    <th>Tên Ngành Học</th>
                    <th>Mô Tả Ngành Học</th>
                    <th>Tên Khoa-Viện</th>
                    <th>Hành động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td width="20">@user.MajorId</td>
                        <td>@user.MajorCode</td>
                        <td>@user.MajorName</td>
                        <td width="350px">@user.MajorDescription</td>
                        <td>@user.Faculty.FacultyName</td>
                        <td>
                            <a class="btn btn-warning btn-sm" asp-action="Edit" asp-controller="Major" asp-route-id="@user.MajorId">Sửa</a>
                            <form asp-action="Delete" asp-controller="Major" asp-route-id="@user.MajorId" method="post" onsubmit=" return confirm('bạn có chắc chắn xoá ngành học này không?')" style="display:inline;">
                                <button type="submit" class="btn btn-danger btn-sm">Xoá</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

</div>