@model QuanLyDiemSinhVien.Models.StudentModel

@{
    ViewData["Title"] = "Thông tin chi tiết sinh viên";
}

<div class="container mt-4">
    <div class="card shadow-sm p-4">
        <div class="row">
            <!-- Ảnh sinh viên -->
            <div class="col-md-3 text-center mb-3">
                @if (Model.Gender == "Nam")
                {
                    <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcQsagjXsTpkIi3TvjeiWP641MqS1noU-QuaaA&s"
                         class="img-fluid rounded-circle mb-3" style="width:150px;" />
                }
                else
                {
                    <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcSbfXbUfIaJj7KTG5NWAIOn7T3_NNKmXYBBbA&s"
                         class="img-fluid rounded-circle mb-3" style="width:150px;" />
                }
                <h5 class="fw-bold">@Model.FullName</h5>
                <span class="text-muted">@Model.StudentCode</span>
            </div>

            <!-- Thông tin chi tiết -->
            <div class="col-md-9">
                <div class="row g-2">
                    <div class="col-sm-6"><strong>Ngày sinh:</strong> @Model.DateOfBirth.ToString("dd/MM/yyyy")</div><br /><br />
                    <div class="col-sm-6"><strong>Giới tính:</strong> @Model.Gender</div><br /><br />

                    <div class="col-sm-6"><strong>Dân tộc:</strong> @Model.Ethnicity </div><br /><br />
                    <div class="col-sm-6"><strong>Tôn giáo:</strong> @Model.Religion</div><br /><br />

                    <div class="col-sm-6"><strong>Quốc tịch:</strong> @Model.Nationality</div><br /><br />
                    <div class="col-sm-6"><strong>CMND/CCCD:</strong> @Model.IdentityNumber</div><br /><br />
                    <div class="col-sm-6"><strong>Địa chỉ:</strong> @Model.Address</div><br /><br />
                    <div class="col-sm-6"><strong>Số điện thoại:</strong> @Model.PhoneNumber</div><br /><br />
                    <div class="col-sm-6"><strong>Email:</strong> @Model.Email</div><br /><br />
                    <div class="col-sm-6"><strong>Lớp:</strong> @Model.Class?.ClassName</div><br /><br />

                    <div class="col-sm-6"><strong>Ngành học:</strong> @Model.Class?.Major?.MajorName</div><br /><br />
                    <div class="col-sm-6"><strong>Khoa:</strong> @Model.Class?.Major?.Faculty?.FacultyName</div><br /><br />

                    <div class="col-sm-6"><strong>Năm học:</strong> @Model.YearOfStudy</div><br /><br />
                    <div class="col-sm-6"><strong>Ngày nhập học:</strong> @Model.EnrollmentDate.ToString("dd/MM/yyyy")</div><br /><br />

                    <div class="col-sm-6">
                        <strong>Trạng thái:</strong>
                        @if (Model.IsActive)
                        {
                            <span class="badge bg-success">Đang học</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Ngừng học</span>
                        }
                    </div>

                    <div class="col-12 mt-3">
                        <strong>Tài khoản hệ thống:</strong>
                        @if (Model.User != null)
                        {
                            <span>@Model.User.UserName</span>
                            <small class="text-muted d-block">(*Tài khoản liên kết; quản lý trong AspNetUsers*)</small>
                        }
                        else
                        {
                            <span class="text-muted">Chưa liên kết tài khoản</span>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="text-end mt-3">
            <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
        </div>
    </div>
</div>
