@model QuanLyDiemSinhVien.Models.StudentModel

@{
    ViewData["Title"] = "Cập nhật Sinh Viên";
}

<h3 style="padding:10px 0px 0px 10px">Cập nhật Sinh Viên</h3>

<div class="col-md-11" style="margin-left:30px">
    <h6>Những form có * là yêu cầu bắt buộc nhập (không được để trống)</h6>

    <form asp-action="Edit" method="post" asp-controller="Student" enctype="multipart/form-data">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="StudentId" />
        <div class="form-group">
            <label asp-for="StudentCode">Mã sinh viên *</label>
            <input asp-for="StudentCode" class="form-control" />
            <span asp-validation-for="StudentCode" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="FullName">Họ và tên *</label>
            <input asp-for="FullName" class="form-control" />
            <span asp-validation-for="FullName" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Gender">Giới tính *</label>
            <select asp-for="Gender" class="form-control">
                <option value="">-- Chọn giới tính --</option>
                <option value="Nam">Nam</option>
                <option value="Nữ">Nữ</option>
            </select>
            <span asp-validation-for="Gender" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="DateOfBirth">Ngày sinh *</label>
            <input asp-for="DateOfBirth" type="date" class="form-control" />
            <span asp-validation-for="DateOfBirth" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label asp-for="Ethnicity">Dân tộc</label>
            <input asp-for="Ethnicity" class="form-control" />
            <span asp-validation-for="Ethnicity" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Religion">Tôn giáo</label>
            <input asp-for="Religion" class="form-control" />
            <span asp-validation-for="Religion" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Nationality">Quốc tịch</label>
            <input asp-for="Nationality" class="form-control" />
            <span asp-validation-for="Nationality" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="IdentityNumber">Số CCCD/CMND</label>
            <input asp-for="IdentityNumber" class="form-control" />
            <span asp-validation-for="IdentityNumber" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Address">Địa chỉ *</label>
            <input asp-for="Address" class="form-control" />
            <span asp-validation-for="Address" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="PhoneNumber">Số điện thoại *</label>
            <input asp-for="PhoneNumber" class="form-control" />
            <span asp-validation-for="PhoneNumber" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Email">Email</label>
            <input asp-for="Email" class="form-control" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="YearOfStudy">Khoá đào tạo *</label>
            <input asp-for="YearOfStudy" type="text" class="form-control" />
            <span asp-validation-for="YearOfStudy" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label asp-for="EnrollmentDate">Ngày nhập học *</label>
            <input asp-for="EnrollmentDate" type="date" class="form-control" />
            <span asp-validation-for="EnrollmentDate" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label for="FacultyId">Chọn Khoa/Viện *</label>
            <select id="FacultyId" class="form-control" asp-items="ViewBag.FacultyList">
                <option value="">-- Chọn Khoa/Viện --</option>
            </select>
            <span asp-validation-for="Class.Major.Faculty.Id" class="text-danger"></span>
        </div>

        <!-- Ngành -->
        <div class="form-group">
            <label for="MajorId">Chọn Ngành Học *</label>
            <select asp-for="MajorId" id="MajorId" class="form-control" asp-items="ViewBag.MajorList">
                <option value="">-- Chọn Ngành Học --</option>
            </select>
            <span asp-validation-for="Class.MajorId" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label for="ClassId">Chọn Lớp *</label>
            <select asp-for="ClassId" class="form-control" asp-items="ViewBag.ClassList">
                <option value="">-- Chọn lớp --</option>
            </select>
            <span asp-validation-for="ClassId" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label for="UserId">Chọn tài khoản</label>
            <select asp-for="UserId" class="form-control" asp-items="ViewBag.Users">
                <option value="">-- Chọn tài khoản --</option>
            </select>
            <span asp-validation-for="UserId" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label asp-for="IsActive">Trạng thái</label>
            <select asp-for="IsActive" class="form-control">
                <option value="true">Đang học</option>
                <option value="false">Tạm nghỉ / Ra trường</option>
            </select>
        </div>

        <div class="form-group mt-3">
            <button type="submit" class="btn btn-primary">Cập nhật Sinh Viên</button>
            <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Khi chọn khoa, load ngành tương ứng
        $('#FacultyId').on('change', function () {
            var facultyId = $(this).val();
            var majorSelect = $('#MajorId');
            var classSelect = $('#ClassId');

            majorSelect.empty().append('<option value="">-- Chọn Ngành Học --</option>');
            classSelect.empty().append('<option value="">-- Chọn Lớp --</option>');

            if (facultyId) {
                $.getJSON('/Admin/Student/GetMajorsByFaculty?facultyId=' + facultyId, function (data) {
                    $.each(data, function (i, item) {
                        majorSelect.append('<option value="' + item.majorId + '">' + item.majorName + '</option>');
                    });
                });
            }
        });

        // Khi chọn ngành, load lớp tương ứng
        $('#MajorId').on('change', function () {
            var majorId = $(this).val();
            var classSelect = $('#ClassId');

            classSelect.empty().append('<option value="">-- Chọn Lớp --</option>');
            if (majorId) {
                $.getJSON('/Admin/Student/GetClassesByMajor?majorId=' + majorId, function (data) {
                    $.each(data, function (i, item) {
                        classSelect.append('<option value="' + item.classId + '">' + item.className + '</option>');
                    });
                });
            }
        });
    </script>
}
