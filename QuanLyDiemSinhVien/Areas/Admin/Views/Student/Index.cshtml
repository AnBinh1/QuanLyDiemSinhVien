@model IEnumerable<QuanLyDiemSinhVien.Models.StudentModel>

@{
    ViewData["Title"] = "Thông tin sinh viên";
}

<div>
    <div class="d-flex align-items-center justify-content-between" style="margin:0px 70px 15px 30px; padding-top:20px;">
        <h3 class="mb-0">Danh sách sinh viên</h3>

        <form asp-action="Search" method="get" class="d-flex" style="max-width:400px;">
            <input type="text" name="searchString" class="form-control me-2" placeholder="Tìm kiếm theo mã hoặc tên" value="@ViewBag.SearchString" />
            <button type="submit" class="btn btn-primary">Tìm</button>
        </form>
    </div>

    <div style="margin-left:25px; margin-bottom:15px">
        <a asp-action="Create" class="btn btn-primary mb-3">Thêm sinh viên mới</a>
        <a style="margin-left:10px" asp-action="ExportToExcel" asp-route-status="all" class="btn btn-warning mb-3">Xuất tất cả sinh viên</a>
        <a style="margin-left:10px" asp-action="ExportToExcel" asp-route-status="active" class="btn btn-warning mb-3">Xuất sinh viên còn học</a>
        <a style="margin-left:10px" asp-action="ExportToExcel" asp-route-status="inactive" class="btn btn-warning mb-3">Xuất sinh viên nghỉ học</a>

    </div>
    

<div >

    <table class="table table-bordered table-hover text-center align-middle">
        <thead class="table-primary">
            <tr>
                <th>STT</th>
                <th>Mã SV</th>
                <th>Họ và tên</th>
                <th>Giới tính</th>
                <th>Ngày sinh</th>
                <th>Số điện thoại</th>
                <th>Email</th>
                <th>Tên lớp</th>
                <th>Ngành học</th>
                <th>Khoa</th>
                <th>Trạng thái</th>
                <th>Hành động</th>
            </tr>
        </thead>
        <tbody>
            @{
                int i = 1;
                foreach (var student in Model)
                {
                    <tr>
                        <td>@i</td>
                        <td>@student.StudentCode</td>
                        <td>@student.FullName</td>
                        <td>@student.Gender</td>
                        <td>@student.DateOfBirth.ToString("dd/MM/yyyy")</td>
                        <td>@student.PhoneNumber</td>
                        <td>@student.Email</td>
                        <td>@student.Class?.ClassName</td>
                        <td>@student.Class?.Major?.MajorName</td>
                        <td>@student.Class?.Major?.Faculty?.FacultyName</td>
                        <td>
                            @if (student.IsActive)
                            {
                                <span class="badge bg-success">Đang học</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Ngừng học</span>
                            }
                        </td>
                        <td>
                            <a asp-action="Details" asp-route-id="@student.StudentId" class="btn btn-info btn-sm">Xem</a>
                            <a asp-action="Edit" asp-route-id="@student.StudentId" class="btn btn-warning btn-sm">Sửa</a>
                            <form asp-action="Delete" asp-route-id="@student.StudentId" method="post" style="display:inline" onsubmit="return confirm('Bạn có chắc chắn muốn xóa sinh viên này không?')">
                                <button type="submit" class="btn btn-danger btn-sm">Xóa</button>
                            </form>
                        </td>
                    </tr>
                    i++;
                }
            }
        </tbody>
    </table>
</div>
