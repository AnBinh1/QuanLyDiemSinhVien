@model IEnumerable<FacultyModel>

@{
    ViewData["Title"] = "Danh sách khoa viện";
}

<div style="margin-left:30px;padding-top:20px">
    <h3>Quản lý khoa viện</h3>

    <a class="btn btn-primary mb-3" asp-action="Create" asp-controller="Faculty">Thêm Khoa-viện</a>

</div>
<div class="col-sm-12" style="margin-left:5px">
    <table class="table table-bordered table-hover" id="myTable">
        <thead>
            <tr>
                <th>Id</th>
                <th>Mã Khoa-Viện</th>
                <th>Tên Khoa-Viện</th>
                <th>Mô Tả Khoa-Viện</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td width="50">@user.Id</td>
                    <td >@user.FacultyCode</td>
                    <td width="200px">@user.FacultyName</td>
                    <td width="550px">@user.FacultyDescription</td>
                    <td>
                        <a class="btn btn-warning btn-sm" asp-action="Edit" asp-controller="Faculty" asp-route-id="@user.Id">Sửa</a>
                        <form asp-action="Delete" asp-controller="Faculty" asp-route-id="@user.Id" method="post" onsubmit=" return confirm('bạn có chắc chắn xoá khoa-viện này không?')" style="display:inline;">
                            <button type="submit" class="btn btn-danger btn-sm">Xoá</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
