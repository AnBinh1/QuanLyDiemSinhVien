@model QuanLyDiemSinhVien.Models.StudentGradeModel

<div style="padding:20px 0 0 20px">
    <h2>Thêm điểm sinh viên</h2>

    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()

        <div class="form-group">
            <label>Lớp học phần</label>
            <select id="SectionId" class="form-control" asp-items="ViewBag.CourseSections">
                <option value="">-- Chọn lớp học phần --</option>
            </select>
        </div>

        <div class="form-group">
            <label>Sinh viên</label>
            <select id="StudentId" name="EnrollmentId" class="form-control" asp-items="ViewBag.Students">
                <option value="">-- Chọn sinh viên --</option>
            </select>
        </div>

        <div class="form-group">
            <label>Điểm quá trình</label>
            <input asp-for="ContinuousAssessment" class="form-control" />
            <span asp-validation-for="ContinuousAssessment" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label>Điểm cuối kỳ</label>
            <input asp-for="FinalExam" class="form-control" />
            <span asp-validation-for="FinalExam" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label>Ghi chú</label>
            <textarea asp-for="Notes" class="form-control"></textarea>
            <span asp-validation-for="Notes" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-success">Lưu</button>
    </form>

</div>
@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        // Khi chọn lớp học phần, load sinh viên
        $("#SectionId").change(function(){
            var sectionId = $(this).val();
            if(sectionId){
                $.getJSON('@Url.Action("GetStudentsBySection", "StudentGrade", new { area = "Admin" })',
                    { sectionId: sectionId },
                    function(data){
                        var options = '<option value="">-- Chọn sinh viên --</option>';
                        $.each(data, function(i, s){
                            options += `<option value="${s.value}">${s.text}</option>`;
                        });
                        $("#StudentId").html(options);
                    }
                );
            } else {
                $("#StudentId").html('<option value="">-- Chọn sinh viên --</option>');
            }
        });
    </script>
}
