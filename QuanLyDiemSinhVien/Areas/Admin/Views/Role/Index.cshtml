@model IEnumerable<IdentityRole>

@{
    ViewData["Title"] = "List Role";
}

<div style="margin-left:30px;padding-top:20px">
    <h3>Quản Lý Vai Trò</h3>
    <a class="btn btn-primary mb-3" asp-action="Create" asp-controller="Role">Thêm Vai Trò</a>
</div>
<div class="col-sm-12" style="margin-left:5px">
    <table class="table table-bordered table-hover" id="myTable">
        <thead>
            <tr>
                <th>Id</th>
                <th>Name</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>@user.Id</td>
                    <td>@user.Name</td>
                    <td>
                        <a class="btn btn-warning btn-sm" asp-action="Edit" asp-controller="Role" asp-route-id="@user.Id">Edit</a>
                        <form asp-action="Delete" asp-controller="Role" asp-route-id="@user.Id" method="post" onsubmit=" return confirm('bạn có chắc chắn xoá vai trò')" style="display:inline;">
                            <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
