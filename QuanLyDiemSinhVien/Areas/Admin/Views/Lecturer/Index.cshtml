@model IEnumerable<QuanLyDiemSinhVien.Models.LecturerModel>

@{
    ViewData["Title"] = "Thông tin giảng viên";
}

<div>
    <div class="d-flex align-items-center justify-content-between" style="margin:0px 70px 15px 30px; padding-top:20px;">
        <h3 class="mb-0">Danh sách giảng viên</h3>

        <form asp-action="Search" method="get" class="d-flex" style="max-width:400px;">
            <input type="text" name="searchString" class="form-control me-2" placeholder="Tìm kiếm theo mã hoặc tên" value="@ViewBag.SearchString" />
            <button type="submit" class="btn btn-primary">Tìm</button>
        </form>
    </div>

    <div style="margin-left:25px; margin-bottom:15px">
        <a asp-action="Create" class="btn btn-primary mb-3">Thêm giảng viên mới</a>
    </div>

<div>
    <table class="table table-bordered table-hover text-center align-middle">
        <thead class="table-primary">
            <tr>
                <th>STT</th>
                <th>Mã GV</th>
                <th>Họ và tên</th>
                <th>Giới tính</th>
                <th>Ngày sinh</th>
                <th>Khoa</th>
                <th>Bộ môn / Ngành</th>
                <th>Email</th>
                <th>Số điện thoại</th>
                <th>Chức danh</th>
                <th>Trạng thái</th>
                <th>Hành động</th>
            </tr>
        </thead>
        <tbody>
            @{
                int i = 1;
                if (Model != null && Model.Any())
                {
                    foreach (var lecturer in Model)
                    {
                        <tr>
                            <td>@i</td>
                            <td>@lecturer.LecturerCode</td>
                            <td>@lecturer.FullName</td>
                            <td>@lecturer.Gender</td>
                            <td>@lecturer.DateOfBirth.ToString("dd/MM/yyyy")</td>
                            <td>@lecturer.Faculty?.FacultyName</td>
                            <td>@lecturer.Major?.MajorName</td>
                            <td>@lecturer.Email</td>
                            <td>@lecturer.PhoneNumber</td>
                            <td>@lecturer.Position</td>
                            <td>
                                @if (lecturer.IsActive)
                                {
                                    <span class="badge bg-success">Đang công tác</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Đã nghỉ</span>
                                }
                            </td>
                            <td>
                                <a asp-action="Details" asp-route-id="@lecturer.LecturerId" class="btn btn-info btn-sm">Xem</a>
                                <a asp-action="Edit" asp-route-id="@lecturer.LecturerId" class="btn btn-warning btn-sm">Sửa</a>
                                <form asp-action="Delete" asp-route-id="@lecturer.LecturerId" method="post" style="display:inline" onsubmit="return confirm('Bạn có chắc chắn muốn xóa giảng viên này không?')">
                                    <button type="submit" class="btn btn-danger btn-sm">Xóa</button>
                                </form>
                            </td>
                        </tr>
                        i++;
                    }
                }
                else
                {
                    <tr>
                        <td colspan="12">Không có dữ liệu giảng viên nào.</td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
